# Frontend Supabase config
# The publishable/anon key is intended for browser use. Keep RLS enabled.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Supabase Edge Functions and local scripts
# Never expose service role keys in frontend code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gumlet video hosting
GUMLET_API_KEY=your-gumlet-api-key
GUMLET_SIGNING_SECRET=your-gumlet-webhook-signing-secret
GUMLET_SOURCE_ID=your-gumlet-source-id

# Optional AI provider key used by the Hubfy AI generation edge function.
HUBFY_OPENAI_API_KEY=your-openai-api-key

# Optional provider integrations used by edge functions.
RESEND_API_KEY=your-resend-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
